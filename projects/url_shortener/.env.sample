# ============================================
# Core
# ============================================
DATABASE_URL="postgresql+psycopg://postgres:postgres@127.0.0.1:5432/url_shortener_db"
BASE_URL="http://localhost:8000"

# ============================================
# Auth / JWT
# ============================================
JWT_SECRET_KEY="change-me-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# CORS (JSON array format)
# ============================================
CORS_ORIGINS='["http://localhost:*"]'
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS='["*"]'
CORS_ALLOW_HEADERS='["*"]'

# ============================================
# Rate Limiting
# ============================================
# Keep disabled for local load testing; enable in controlled environments.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=minute

# ============================================
# Redis
# ============================================
REDIS_URL="redis://localhost:6379"
REDIS_DB_CACHE=0
REDIS_DB_ANALYTICS=1
REDIS_DB_QUEUE=2
REDIS_MAX_CONNECTIONS=100

# ============================================
# Database Pool
# ============================================
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_RECYCLE=3600

# ============================================
# Worker
# ============================================
WORKER_BATCH_SIZE=1000
WORKER_FLUSH_INTERVAL=5
